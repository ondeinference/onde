# https://dart.dev/guides/libraries/private-files
# Created by `dart pub`
.dart_tool/

# Avoid committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock

# Rust build artifacts (multi-GB)
rust/target/

# Precompiled static libraries — built from source via podspec / CMake / Gradle
ios/*.a
macos/*.a
**/*.so
**/*.dylib
**/*.dll
**/*.lib

# Flutter example app build outputs
example/build/
example/.dart_tool/

# Flutter-generated plugin registration files — regenerated on every `flutter pub get`
example/**/GeneratedPluginRegistrant.java
example/**/GeneratedPluginRegistrant.swift
example/**/GeneratedPluginRegistrant.m
example/**/GeneratedPluginRegistrant.h

# Dev logs
logs/

# IDE / editor files
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# macOS metadata
.DS_Store
**/.DS_Store

# Flutter-generated plugin registrant — regenerated by `flutter pub get`;
# never manually edited, must not be tracked or pub publish will fail on CI.
example/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
